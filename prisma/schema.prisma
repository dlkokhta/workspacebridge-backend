generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id        String  @id @default(uuid())
  firstname String? @map("first_name")
  lastname  String? @map("last_name")
  email     String  @unique
  password  String?

  picture String?

  isVerified Boolean @default(false) @map("is_verified")

  isTwoFactorEnabled Boolean @default(false) @map("is_two_factor_enabled")
  twoFactorSecret    String? @map("two_factor_secret")

  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")

  role UserRole @default(FREELANCER)
  plan UserPlan @default(FREE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  method   AuthMethod @default(CREDENTIALS)
  Accounts Account[]
  Session  Session[]

  ownedWorkspaces      Workspace[]         @relation("OwnedWorkspaces")
  workspaceMemberships WorkspaceMember[]   @relation("WorkspaceMemberships")
  sentMessages         Message[]           @relation("SentMessages")
  whiteboardComments   WhiteboardComment[] @relation("WhiteboardComments")
  whiteboardVersions   WhiteboardVersion[] @relation("WhiteboardVersions")
  uploadedFiles        File[]              @relation("UploadedFiles")

  @@map("users")
}

model Account {
  id String @id @default(uuid())

  type              String
  provider          String
  providerAccountId String? @map("provider_account_id")

  refreshToken String?   @map("refresh_token")
  accessToken  String?   @map("access_token")
  expiresAt    DateTime? @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User?  @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Token {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  type      TokenType
  expiresIn DateTime  @map("expires_in")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email, type])
  @@index([expiresIn])
  @@map("tokens")
}

model Session {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  refreshToken String   @map("refresh_token")
  ip           String?
  userAgent    String?
  expiresAt    DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("sessions")
}

model Workspace {
  id          String          @id @default(uuid())
  name        String
  description String?
  color       String          @default("#5a8a6b")
  status      WorkspaceStatus @default(ACTIVE)

  ownerId String @map("owner_id")
  owner   User   @relation("OwnedWorkspaces", fields: [ownerId], references: [id])

  members     WorkspaceMember[]
  invites     WorkspaceInvite[]
  messages    Message[]
  whiteboards Whiteboard[]
  files       File[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("workspaces")
}

model Message {
  id      String @id @default(uuid())
  content String

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  senderId String @map("sender_id")
  sender   User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([workspaceId, createdAt])
  @@map("messages")
}

model Whiteboard {
  id String @id @default(uuid())

  name String @default("Untitled board")

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  elements Json  @default("[]")
  appState Json? @map("app_state")
  files    Json? @map("files")

  comments WhiteboardComment[]
  versions WhiteboardVersion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([workspaceId])
  @@map("whiteboards")
}

model WhiteboardVersion {
  id String @id @default(uuid())

  whiteboardId String     @map("whiteboard_id")
  whiteboard   Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)

  elements Json  @default("[]")
  appState Json? @map("app_state")
  files    Json? @map("files")

  label String?
  type  WhiteboardVersionType @default(MANUAL)

  createdById String @map("created_by_id")
  createdBy   User   @relation("WhiteboardVersions", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([whiteboardId, createdAt])
  @@map("whiteboard_versions")
}

model WhiteboardComment {
  id String @id @default(uuid())

  whiteboardId String     @map("whiteboard_id")
  whiteboard   Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)

  elementId String @map("element_id")

  authorId String @map("author_id")
  author   User   @relation("WhiteboardComments", fields: [authorId], references: [id], onDelete: Cascade)

  body String @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([whiteboardId, elementId])
  @@map("whiteboard_comments")
}

model File {
  id String @id @default(uuid())

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  uploadedById String @map("uploaded_by_id")
  uploadedBy   User   @relation("UploadedFiles", fields: [uploadedById], references: [id], onDelete: Cascade)

  name       String
  mimeType   String @map("mime_type")
  size       Int
  storageKey String @unique @map("storage_key")

  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([workspaceId, deletedAt, createdAt])
  @@map("files")
}

model WorkspaceInvite {
  id    String  @id @default(uuid())
  token String  @unique @default(uuid())
  email String?

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@index([workspaceId])
  @@map("workspace_invites")
}

model WorkspaceMember {
  id   String              @id @default(uuid())
  role WorkspaceMemberRole @default(CLIENT)

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation("WorkspaceMemberships", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

enum WorkspaceStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum WorkspaceMemberRole {
  FREELANCER
  CLIENT
}

enum UserRole {
  FREELANCER
  CLIENT
  ADMIN
}

enum UserPlan {
  FREE
  PRO
  BUSINESS
}

enum AuthMethod {
  CREDENTIALS
  GOOGLE
}

enum TokenType {
  VERIFICATION
  TWO_FACTOR
  PASSWORD_RESET
}

enum WhiteboardVersionType {
  MANUAL
  AUTO
}
