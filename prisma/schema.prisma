generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id        String  @id @default(uuid())
  firstname String? @map("first_name")
  lastname  String? @map("last_name")
  email     String  @unique
  password  String?

  picture String?

  isVerified Boolean @default(false) @map("is_verified")

  isTwoFactorEnabled Boolean @default(false) @map("is_two_factor_enabled")
  twoFactorSecret    String? @map("two_factor_secret")

  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")

  role   UserRole   @default(FREELANCER)
  plan   UserPlan   @default(FREE)
  status UserStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  method          AuthMethod        @default(CREDENTIALS)
  Accounts        Account[]
  Session         Session[]
  passwordHistory PasswordHistory[]
  backupCodes     BackupCode[]
  credentials     Credential[]
  avatar          UserAvatar?

  ownedWorkspaces      Workspace[]         @relation("OwnedWorkspaces")
  workspaceMemberships WorkspaceMember[]   @relation("WorkspaceMemberships")
  sentMessages         Message[]           @relation("SentMessages")
  whiteboardComments   WhiteboardComment[] @relation("WhiteboardComments")
  whiteboardVersions   WhiteboardVersion[] @relation("WhiteboardVersions")
  uploadedFiles        File[]              @relation("UploadedFiles")
  addedSharedLinks     SharedLink[]        @relation("AddedSharedLinks")
  createdTasks         SharedTask[]        @relation("CreatedTasks")
  privateTasks         PrivateTask[]       @relation("PrivateTasks")
  notifications        Notification[]      @relation("UserNotifications")
  fileComments         FileComment[]       @relation("FileComments")
  chatReads            ChatRead[]          @relation("UserChatReads")

  @@map("users")
}

model Account {
  id String @id @default(uuid())

  type              String
  provider          String
  providerAccountId String? @map("provider_account_id")

  refreshToken String?   @map("refresh_token")
  accessToken  String?   @map("access_token")
  expiresAt    DateTime? @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User?  @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Token {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  type      TokenType
  expiresIn DateTime  @map("expires_in")
  createdAt DateTime  @default(now()) @map("created_at")

  // Set for EMAIL_CHANGE tokens: the user requesting the change. `email` then
  // holds the pending NEW address; the current address is read from the user.
  userId String? @map("user_id")

  @@index([email, type])
  @@index([expiresIn])
  @@map("tokens")
}

// Short-lived single-use code used to exchange a Google OAuth redirect for
// real tokens without putting the access token in the URL. The code lands
// in the browser via ?code=… and is immediately POSTed to /auth/exchange
// where the backend issues the actual access token + refresh cookie.
model AuthExchangeCode {
  id        String   @id @default(uuid())
  code      String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("auth_exchange_codes")
}

// Tracks each 2FA pre-auth tempToken by its jti (JWT ID) claim so we can
// (a) reject replays of an already-consumed token, and (b) cap brute-force
// guesses per token regardless of source IP. Without this an attacker who
// steals a tempToken could replay it within its 5-minute window, and a
// distributed attacker could outflank the per-IP throttler.
model TwoFactorAttempt {
  id        String   @id @default(uuid())
  jti       String   @unique
  userId    String   @map("user_id")
  attempts  Int      @default(0)
  consumed  Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("two_factor_attempts")
}

// Staging area for a 2FA TOTP secret that hasn't been confirmed yet.
// /auth/2fa/generate writes here; /auth/2fa/enable promotes the secret
// to users.two_factor_secret only after a valid TOTP code is provided.
// This avoids orphan secrets sitting on the user row when setup is
// abandoned and removes a footgun for future logic that might check
// twoFactorSecret IS NOT NULL.
model PendingTwoFactorSetup {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  secret    String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("pending_two_factor_setups")
}

model Session {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  refreshToken         String    @map("refresh_token")
  previousRefreshToken String?   @map("previous_refresh_token")
  tokenRotatedAt       DateTime? @map("token_rotated_at")
  ip                   String?
  userAgent            String?
  expiresAt            DateTime  @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("sessions")
}

model BackupCode {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  // SHA-256 hash of a one-time 2FA recovery code.
  code String

  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("backup_codes")
}

model Credential {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  // Base64URL credential id reported by the authenticator (globally unique).
  credentialId String @unique @map("credential_id")
  // Base64URL-encoded COSE public key used to verify assertions.
  publicKey String @map("public_key")
  // Signature counter, for cloned-authenticator detection.
  counter Int @default(0)
  // Comma-joined transport hints (e.g. "internal,hybrid").
  transports String?
  // "singleDevice" | "multiDevice" — a multi-device credential is a syncable passkey.
  deviceType String? @map("device_type")
  backedUp   Boolean @default(false) @map("backed_up")
  // Optional user-facing label, e.g. "MacBook Touch ID".
  name String?

  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  @@index([userId])
  @@map("credentials")
}

// A user-uploaded avatar, re-encoded to a square WebP and stored as bytes.
// Kept in its own table (one row per user) so the heavy blob is never loaded
// by the frequent User look-ups (auth, profile, etc.). `hash` is the content
// digest used for the public URL's `?v=` cache-bust.
model UserAvatar {
  userId String @id @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  data        Bytes
  contentType String @default("image/webp") @map("content_type")
  hash        String

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_avatars")
}

model PasswordHistory {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  // argon2 hash of a previously-used password, kept to block reuse.
  password String

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_history")
}

model Workspace {
  id          String          @id @default(uuid())
  name        String
  description String?
  color       String          @default("#5a8a6b")
  status      WorkspaceStatus @default(ACTIVE)

  ownerId String @map("owner_id")
  owner   User   @relation("OwnedWorkspaces", fields: [ownerId], references: [id])

  members       WorkspaceMember[]
  invites       WorkspaceInvite[]
  messages      Message[]
  whiteboards   Whiteboard[]
  files         File[]
  sharedLinks   SharedLink[]
  sharedTasks   SharedTask[]
  privateTasks  PrivateTask[]
  notifications Notification[]
  chatReads     ChatRead[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("workspaces")
}

/// Tracks how far each user has read a workspace's chat. A message is "seen"
/// by a user when their `lastReadAt` is >= the message's `createdAt`. One row
/// per (workspace, user) — covers the owner (not a WorkspaceMember) and every
/// member alike.
model ChatRead {
  id String @id @default(uuid())

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation("UserChatReads", fields: [userId], references: [id], onDelete: Cascade)

  lastReadAt DateTime @map("last_read_at")

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@map("chat_reads")
}

model Message {
  id      String @id @default(uuid())
  content String

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  senderId String @map("sender_id")
  sender   User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([workspaceId, createdAt])
  @@map("messages")
}

model Whiteboard {
  id String @id @default(uuid())

  name String @default("Untitled board")

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  elements Json  @default("[]")
  appState Json? @map("app_state")
  files    Json? @map("files")

  comments WhiteboardComment[]
  versions WhiteboardVersion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([workspaceId])
  @@map("whiteboards")
}

model WhiteboardVersion {
  id String @id @default(uuid())

  whiteboardId String     @map("whiteboard_id")
  whiteboard   Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)

  elements Json  @default("[]")
  appState Json? @map("app_state")
  files    Json? @map("files")

  label String?
  type  WhiteboardVersionType @default(MANUAL)

  createdById String @map("created_by_id")
  createdBy   User   @relation("WhiteboardVersions", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([whiteboardId, createdAt])
  @@map("whiteboard_versions")
}

model WhiteboardComment {
  id String @id @default(uuid())

  whiteboardId String     @map("whiteboard_id")
  whiteboard   Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)

  elementId String @map("element_id")

  authorId String @map("author_id")
  author   User   @relation("WhiteboardComments", fields: [authorId], references: [id], onDelete: Cascade)

  body String @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([whiteboardId, elementId])
  @@map("whiteboard_comments")
}

model File {
  id String @id @default(uuid())

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Files belong to the workspace, not to the uploader. When a user is
  // deleted the uploader label is cleared (UI shows "Deleted user"); the
  // file itself stays so the workspace owner does not lose work uploaded
  // by a client who later closes their account.
  uploadedById String? @map("uploaded_by_id")
  uploadedBy   User?   @relation("UploadedFiles", fields: [uploadedById], references: [id], onDelete: SetNull)

  name       String
  mimeType   String @map("mime_type")
  size       Int
  storageKey String @unique @map("storage_key")

  comments FileComment[]

  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([workspaceId, deletedAt, createdAt])
  @@index([deletedAt])
  @@map("files")
}

model FileComment {
  id String @id @default(uuid())

  fileId String @map("file_id")
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  // Comments outlive their author the same way files do: if a client closes
  // their account the comment stays (the UI shows "Deleted user").
  authorId String? @map("author_id")
  author   User?   @relation("FileComments", fields: [authorId], references: [id], onDelete: SetNull)

  body String @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([fileId, createdAt])
  @@map("file_comments")
}

model SharedLink {
  id String @id @default(uuid())

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Same rule as files: links belong to the workspace, not the adder.
  // When a user is deleted the attribution is cleared (UI shows
  // "Added by deleted user"); the link itself stays so the freelancer
  // does not lose context shared by a client who later leaves.
  addedById String? @map("added_by_id")
  addedBy   User?   @relation("AddedSharedLinks", fields: [addedById], references: [id], onDelete: SetNull)

  url   String
  title String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([workspaceId, createdAt])
  @@map("shared_links")
}

model SharedTask {
  id String @id @default(uuid())

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Same rule as files / shared links: tasks belong to the workspace, not
  // the creator. When a user is deleted the attribution is cleared (UI
  // shows "Created by deleted user"); the task itself stays so the
  // freelancer does not lose a todo list a client helped build.
  createdById String? @map("created_by_id")
  createdBy   User?   @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: SetNull)

  title  String
  status TaskStatus @default(TODO)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([workspaceId, createdAt])
  @@map("shared_tasks")
}

model PrivateTask {
  id String @id @default(uuid())

  // Always belongs to a user — these are personal notes/todos.
  userId String @map("user_id")
  user   User   @relation("PrivateTasks", fields: [userId], references: [id], onDelete: Cascade)

  // Optional workspace for context — lets the freelancer filter "private
  // tasks related to this client" while still owning the task themselves.
  workspaceId String?    @map("workspace_id")
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  title  String
  status TaskStatus @default(TODO)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, workspaceId, createdAt])
  @@map("private_tasks")
}

model WorkspaceInvite {
  id    String  @id @default(uuid())
  token String  @unique @default(uuid())
  email String?

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@index([workspaceId])
  @@map("workspace_invites")
}

model WorkspaceMember {
  id   String              @id @default(uuid())
  role WorkspaceMemberRole @default(CLIENT)

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation("WorkspaceMemberships", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  actorId    String   @map("actor_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([actorId])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model Notification {
  id   String           @id @default(uuid())
  type NotificationType

  userId String @map("user_id")
  user   User   @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  data   Json?
  isRead Boolean @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum WorkspaceStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum WorkspaceMemberRole {
  FREELANCER
  CLIENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  FREELANCER
  CLIENT
  ADMIN
}

enum UserPlan {
  FREE
  PRO
  BUSINESS
}

enum AuthMethod {
  CREDENTIALS
  GOOGLE
}

enum TokenType {
  VERIFICATION
  TWO_FACTOR
  PASSWORD_RESET
  EMAIL_CHANGE
}

enum WhiteboardVersionType {
  MANUAL
  AUTO
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum NotificationType {
  NEW_MESSAGE
  FILE_COMMENT
  TASK_ASSIGNED
  WHITEBOARD_COMMENT
}
